#!/bin/sh
# pre-push — slower checks that run before any push
#
# INSTALL:
#   cp hooks/pre-push .git/hooks/pre-push
#   chmod +x .git/hooks/pre-push

set -e

BOLD='\033[1m'
RED='\033[0;31m'
RESET='\033[0m'

fail() {
    printf "${BOLD}${RED}pre-push: FAILED — %s${RESET}\n" "$1" >&2
    exit 1
}

step() {
    printf "pre-push: running %s ...\n" "$1"
}

# ── 1. Doc build (mirrors CI RUSTDOCFLAGS=-D warnings) ────────────────────

step "cargo doc --no-deps"
RUSTDOCFLAGS="-D warnings" cargo doc --no-deps \
    || fail "cargo doc (fix rustdoc warnings above)"

# ── 2. Integration tests ───────────────────────────────────────────────────

step "cargo test --all-features"
cargo test --all-features || fail "cargo test --all-features (integration tests failed)"

printf "pre-push: all checks passed.\n"
