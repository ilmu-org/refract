#!/bin/sh
# pre-commit — mirrors CI checks exactly
#
# INSTALL:
#   cp hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Requires: cargo-audit, cargo-deny

set -e

BOLD='\033[1m'
RED='\033[0;31m'
RESET='\033[0m'

fail() {
    printf "${BOLD}${RED}pre-commit: FAILED — %s${RESET}\n" "$1" >&2
    exit 1
}

step() {
    printf "pre-commit: running %s ...\n" "$1"
}

# ── 1. Formatting ──────────────────────────────────────────────────────────

step "cargo fmt --check"
cargo fmt --check || fail "cargo fmt --check (run 'cargo fmt' to fix)"

# ── 2. Linting ────────────────────────────────────────────────────────────

step "cargo clippy --all-targets --all-features"
cargo clippy --all-targets --all-features -- -D warnings -W clippy::pedantic \
    || fail "cargo clippy (fix the warnings above)"

# ── 3. Tests ──────────────────────────────────────────────────────────────

step "cargo test --all-features"
cargo test --all-features || fail "cargo test --all-features"

# ── 4. Security audit ─────────────────────────────────────────────────────

step "cargo audit"
cargo audit || fail "cargo audit (vulnerability found)"

# ── 5. License and dependency policy ──────────────────────────────────────

step "cargo deny check"
cargo deny check || fail "cargo deny check (policy violation)"

# ── 6. Documentation build ────────────────────────────────────────────────

step "cargo doc --no-deps"
RUSTDOCFLAGS="-D warnings" cargo doc --no-deps || fail "cargo doc (fix rustdoc warnings above)"

printf "pre-commit: all checks passed.\n"
