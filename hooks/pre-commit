#!/bin/sh
# pre-commit — fast quality gate for ilmu Rust projects
#
# INSTALL:
#   cp pre-commit.sh .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Runs in <30 seconds by limiting tests to library unit tests only.
# Integration tests and doc tests are left for CI.

set -e

# ── Helpers ────────────────────────────────────────────────────────────────

BOLD='\033[1m'
RED='\033[0;31m'
RESET='\033[0m'

fail() {
    printf "${BOLD}${RED}pre-commit: FAILED — %s${RESET}\n" "$1" >&2
    exit 1
}

step() {
    printf "pre-commit: running %s ...\n" "$1"
}

# ── 1. Formatting ──────────────────────────────────────────────────────────

step "cargo fmt --check"
cargo fmt --check || fail "cargo fmt --check (run 'cargo fmt' to fix)"

# ── 2. Linting ────────────────────────────────────────────────────────────

step "cargo clippy --all-targets --all-features"
cargo clippy --all-targets --all-features -- -D warnings -W clippy::pedantic \
    || fail "cargo clippy (fix the warnings above)"

# ── 3. Unit tests only (fast) ─────────────────────────────────────────────

step "cargo test --lib"
cargo test --lib || fail "cargo test --lib (unit tests failed)"

printf "pre-commit: all checks passed.\n"
